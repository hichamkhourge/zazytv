# 2captcha Configuration
# Get your API key from https://2captcha.com/enterpage
TWOCAPTCHA_API_KEY=your_2captcha_api_key_here

# URLs
BASE_URL=https://zazyhost.com
HOME_URL=https://zazytv.com/

# Login Credentials (optional - only needed if SKIP_LOGIN=False)
LOGIN_EMAIL=your@email.com
LOGIN_PASSWORD=yourpassword
SKIP_LOGIN=True

# Promo Code (optional)
PROMO_CODE=

# IBO Player Configuration
# Get these values from your IBO Player account
# Cookie: From browser DevTools > Application > Cookies while logged into iboplayer.com
IBOPLAYER_COOKIE=your_iboplayer_cookie_here
# Playlist URL ID: From IBO Player device settings
IBOPLAYER_PLAYLIST_URL_ID=your_playlist_url_id_here
# Playlist Name: Display name for your playlist
IBOPLAYER_PLAYLIST_NAME=Zazy
# Playlist URL: Xtream Codes server URL
IBOPLAYER_PLAYLIST_URL=http://live.zazytv.com

# Telegram Notification Configuration (Optional)
# Get your bot token from @BotFather on Telegram
# See TELEGRAM_SETUP.md for detailed instructions
TELEGRAM_ENABLED=False
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Docker/Automation Settings (Optional)
# HEADLESS: Run Chrome in headless mode (True for Docker, False for local GUI)
HEADLESS=True
# AUTO_EXIT: Exit after completion (True for Docker/cron, False to keep browser open)
AUTO_EXIT=True
# TZ: Timezone for cron schedule (e.g., America/New_York, Europe/London, Asia/Dubai)
TZ=UTC
